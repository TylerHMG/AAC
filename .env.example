# Anthropic API key for AI word suggestions.
#
# IMPORTANT: this is a SERVER-side variable (no VITE_ prefix), so it is NEVER
# bundled into the browser. It is read only by the proxy in api/generate.ts.
#
# Local dev:  copy this file to .env.local, paste your key after the =, then run
#             `vercel dev` (NOT `npm run dev`) so the /api/generate function runs.
#             `npm run dev` serves the UI only — AI generation needs the proxy.
# Production: set ANTHROPIC_API_KEY in the Vercel dashboard
#             (Project → Settings → Environment Variables). Do not commit .env.local.
ANTHROPIC_API_KEY=

# Access passphrase for the AI proxy (server-side only).
# If set, callers must enter this passphrase in the app before they can generate
# words — this stops anyone with just the URL from spending your API credits.
# Pick any phrase, set the SAME value in the Vercel dashboard, and share it only
# with your select users. Leave blank to keep the proxy open (personal use only).
AAC_ACCESS_CODE=
